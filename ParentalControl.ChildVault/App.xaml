<Application x:Class="ParentalControl.ChildVault.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="App_Startup">
    <Application.Resources>
        <!-- Same resource keys as the parent UI — populated at runtime from theme.json -->
        <SolidColorBrush x:Key="AppBg"         Color="#1E1E2E"/>
        <SolidColorBrush x:Key="CardBg"        Color="#313244"/>
        <SolidColorBrush x:Key="CardHover"     Color="#45475A"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#585B70"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#CDD6F4"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A6ADC8"/>
    </Application.Resources>
</Application>
