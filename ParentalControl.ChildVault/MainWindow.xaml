<Window x:Class="ParentalControl.ChildVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My Passwords — ParentGuard"
        Width="440" Height="540"
        MinWidth="440" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="*"/>     <!-- content -->
        </Grid.RowDefinitions>

        <!-- Header — matches the parent UI's sidebar/card style -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="20,13">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔐" FontSize="17" VerticalAlignment="Center" Margin="0,0,9,0"/>
                <TextBlock Text="My Passwords" FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── PIN screen ── -->
        <Grid x:Name="PinPanel" Grid.Row="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        MaxWidth="300">

                <TextBlock x:Name="PinHint"
                           Text="Enter your vault PIN to view your passwords."
                           Foreground="{DynamicResource TextSecondary}" FontSize="13"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,0,0,12">
                    <PasswordBox x:Name="PinBox"
                                 Width="170" Height="40"
                                 Background="{DynamicResource CardBg}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                 Padding="12,4" FontSize="14" MaxLength="8"
                                 KeyDown="PinBox_KeyDown"
                                 Margin="0,0,10,0"/>
                    <Button x:Name="UnlockBtn"
                            Content="Unlock" Width="90" Height="40"
                            Background="{DynamicResource BorderColor}"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderThickness="0" FontWeight="Bold" FontSize="13"
                            Cursor="Hand" Click="Unlock_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.45"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <TextBlock x:Name="PinError"
                           FontSize="12" Foreground="#F38BA8"
                           TextWrapping="Wrap" TextAlignment="Center"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ── Vault screen ── -->
        <Grid x:Name="VaultPanel" Grid.Row="1" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                          Padding="18,12,18,0">
                <StackPanel x:Name="EntriesPanel"/>
            </ScrollViewer>

            <!-- Bottom bar: Refresh + Lock -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0"
                    Padding="16,10,16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="LastRefreshedText"
                               Grid.Column="0"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11" VerticalAlignment="Center"/>

                    <!-- Refresh button -->
                    <Button Grid.Column="1"
                            Content="Refresh" Height="34" Width="86"
                            Background="{DynamicResource CardHover}"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderThickness="0" FontSize="13" Cursor="Hand"
                            Click="Refresh_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource BorderColor}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Lock button -->
                    <Button Grid.Column="3"
                            Content="Lock" Height="34" Width="86"
                            Background="{DynamicResource CardHover}"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderThickness="0" FontSize="13" Cursor="Hand"
                            Click="Lock_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource BorderColor}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
