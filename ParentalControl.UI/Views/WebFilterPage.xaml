<Page x:Class="ParentalControl.UI.Views.WebFilterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}" Title="Web Filter">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Website Filter" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>

        <!-- Mode toggle -->
        <Border Grid.Row="1" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Filter Mode" Foreground="{DynamicResource TextPrimary}"
                           FontWeight="SemiBold" Margin="0,0,0,10"/>
                <CheckBox x:Name="AllowModeToggle" Content="Allow Mode"
                          Style="{StaticResource ToggleSwitch}"
                          Checked="FilterMode_Changed" Unchecked="FilterMode_Changed"/>
                <TextBlock x:Name="ModeDescText" Margin="0,8,0,0" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondary}" FontSize="12"
                           Text="Block Mode: listed domains are blocked; all other sites are accessible."/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,16" TextWrapping="Wrap"
                   x:Name="PageDescText"
                   Text="Block websites by domain. Blocked domains are added to the system hosts file. Enter domain only (e.g. tiktok.com)."/>

        <!-- Add domain -->
        <Grid Grid.Row="3" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="DomainBox" Grid.Column="0" Height="36"
                     Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                     BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                     Padding="8,4" ToolTip="domain.com (e.g. tiktok.com)"
                     FontSize="13" Margin="0,0,8,0"/>
            <Button x:Name="AddDomainButton" Grid.Column="1" Content="Block Domain" Height="36" Padding="16,0"
                    Background="#F38BA8" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="AddDomain_Click"/>
        </Grid>

        <!-- Domain list -->
        <Border Grid.Row="4" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="8">
            <DataGrid x:Name="WebRulesGrid" AutoGenerateColumns="False"
                      Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                      BorderThickness="0" GridLinesVisibility="None"
                      HeadersVisibility="Column" IsReadOnly="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      RowBackground="Transparent" AlternatingRowBackground="{DynamicResource AltRowBg}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="*"/>
                    <DataGridCheckBoxColumn Header="Blocked" Binding="{Binding IsBlocked}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Allowed" Binding="{Binding IsAllowed}" Width="80"/>
                    <DataGridTemplateColumn Header="Remove" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" Width="30" Height="24"
                                        Background="#F38BA8" Foreground="#1E1E2E"
                                        FontWeight="Bold" BorderThickness="0"
                                        Tag="{Binding Id}"
                                        Click="DeleteDomain_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Save &amp; Apply" Height="38" Padding="16,0"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,12,0"
                    Click="SaveButton_Click"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Foreground="#A6E3A1" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Page>
