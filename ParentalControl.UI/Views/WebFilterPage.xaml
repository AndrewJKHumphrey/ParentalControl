<Page x:Class="ParentalControl.UI.Views.WebFilterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}" Title="Web Filter">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: heading -->
            <RowDefinition Height="Auto"/>  <!-- 1: description -->
            <RowDefinition Height="Auto"/>  <!-- 2: profile selector -->
            <RowDefinition Height="Auto"/>  <!-- 3: allow mode toggle -->
            <RowDefinition Height="Auto"/>  <!-- 4: add domain row -->
            <RowDefinition Height="Auto"/>  <!-- 5: save row -->
            <RowDefinition Height="*"/>     <!-- 6: individual domain list -->
            <RowDefinition Height="Auto"/>  <!-- 7: content tags section -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Web Filter" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"
                       Text="Each domain entry is marked Blocked or Allowed. With Allow Mode off, only Blocked entries are blocked and everything else is accessible. With Allow Mode on, everything is blocked except Allowed entries. Content Tags let you block entire categories at once."/>
            <!-- Extension install notice -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Browser Extension Required" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,3"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                   Text="The ParentGuard extension must be manually loaded in Edge or Chrome to enforce web filtering. Click to open the extension folder, then follow the steps in Help."/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Open Extension Folder" Margin="16,0,0,0"
                            Height="34" Padding="14,0" Background="#89B4FA" Foreground="#1E1E2E"
                            FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"
                            Click="OpenExtensionFolder_Click"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Profile selector -->
        <Border Grid.Row="2" Background="{DynamicResource CardBg}" CornerRadius="8"
                Padding="12,8" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Profile:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,12,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="ProfileSelector" Width="200"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="ProfileSelector_Changed"/>
            </StackPanel>
        </Border>

        <!-- Allow Mode toggle -->
        <Border Grid.Row="3" Background="{DynamicResource CardBg}" CornerRadius="8"
                Padding="12,10" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Allow Mode:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,12,0" FontWeight="SemiBold"/>
                <CheckBox x:Name="AllowModeToggle" VerticalAlignment="Center"
                          Checked="AllowModeToggle_Changed" Unchecked="AllowModeToggle_Changed"/>
                <TextBlock x:Name="AllowModeLabel" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" Margin="8,0,0,0"
                           Text="Off — only Blocked entries are blocked; everything else is accessible"/>
            </StackPanel>
        </Border>

        <!-- Add domain -->
        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="DomainBox" Grid.Column="0" Height="36"
                     Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                     BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                     Padding="8,4" FontSize="13" Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     Tag="Domain (e.g. example.com)"
                     GotFocus="DomainBox_GotFocus" LostFocus="DomainBox_LostFocus"
                     KeyDown="DomainBox_KeyDown"/>
            <ComboBox x:Name="EntryTypeBox" Grid.Column="1" Width="110" Height="36"
                      Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                      BorderBrush="{DynamicResource BorderColor}" Margin="0,0,8,0"
                      VerticalContentAlignment="Center">
                <ComboBoxItem Content="Blocked" IsSelected="True"/>
                <ComboBoxItem Content="Allowed"/>
            </ComboBox>
            <Button Grid.Column="2" Content="Add Domain" Height="36" Padding="16,0"
                    Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="AddDomain_Click" Margin="0,0,8,0"/>
            <Button Grid.Column="3" Content="Remove Selected" Height="36" Padding="16,0"
                    Background="#F38BA8" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="RemoveDomain_Click"/>
        </Grid>

        <!-- Save row -->
        <WrapPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Save for Current Profile" Height="36" Padding="20,0"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="SaveButton_Click" Margin="0,0,8,8"/>
            <Button Content="Save to All Profiles" Height="36" Padding="20,0"
                    Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="SaveToAllButton_Click" Margin="0,0,8,8"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
        </WrapPanel>

        <!-- Individual domain list -->
        <Border Grid.Row="6" Background="{DynamicResource CardBg}" CornerRadius="8"
                Padding="0" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Individual Domain Rules"
                           FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                           Margin="12,10,12,6"/>
                <DataGrid x:Name="DomainsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserResizeRows="False" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="Transparent"
                          RowBackground="{DynamicResource CardBg}"
                          AlternatingRowBackground="{DynamicResource AltRowBg}"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderThickness="0"
                          HorizontalGridLinesBrush="{DynamicResource BorderColor}"
                          SelectionMode="Extended">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Domain / Pattern" Binding="{Binding Pattern}"
                                           Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding ModeLabel}"
                                           Width="120" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- Content Tags section -->
        <Border Grid.Row="7" Background="{DynamicResource CardBg}" CornerRadius="8"
                Padding="12" Margin="0,0,0,0">
            <DockPanel>

                <!-- Header row: title + Sync All button -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Content Tags" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    <Button x:Name="SyncAllBtn" Grid.Column="1" Content="Sync All" Height="28" Padding="12,0"
                            Background="#CBA6F7" Foreground="#1E1E2E" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand" Click="SyncAll_Click"/>
                </Grid>

                <!-- Sync progress (hidden when idle) -->
                <StackPanel x:Name="SyncProgressPanel" DockPanel.Dock="Top"
                            Margin="0,0,0,8" Visibility="Collapsed">
                    <TextBlock x:Name="SyncProgressLabel"
                               Foreground="{DynamicResource TextSecondary}" FontSize="12"
                               Margin="0,0,0,4"/>
                    <ProgressBar x:Name="SyncProgressBar" Height="6"
                                 Minimum="0" Maximum="100" Value="0"
                                 Foreground="#CBA6F7" BorderThickness="0"
                                 Background="{DynamicResource BorderColor}"/>
                </StackPanel>

                <!-- Copy button pinned to bottom -->
                <Button DockPanel.Dock="Bottom" Content="Copy to All Profiles" Height="30" Padding="12,0"
                        Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="CopyTagsToAllProfiles_Click"
                        Margin="0,8,0,0" HorizontalAlignment="Left"/>

                <!-- Tags list -->
                <ListBox x:Name="TagsListBox"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0,3"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                          Checked="TagEnabled_Changed" Unchecked="TagEnabled_Changed"
                                          VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding CountLabel}"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="11" Margin="6,1,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </CheckBox>
                                <Button Grid.Column="1" Content="View ▸" Height="26" Padding="10,0"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TextSecondary}"
                                        FontSize="11" BorderThickness="1"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        Cursor="Hand" Tag="{Binding}"
                                        Click="ViewDomains_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

    </Grid>
    </ScrollViewer>
</Page>
