<Page x:Class="ParentalControl.UI.Views.WebFilterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}" Title="Web Filter">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Web Filter" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,20" TextWrapping="Wrap"
                   Text="Block or allow websites per profile. In Block mode, listed domains are blocked. In Allow mode, only listed domains are allowed. Requires the ParentGuard browser extension to be installed."/>

        <!-- Profile selector -->
        <Border Grid.Row="2" Background="{DynamicResource CardBg}" CornerRadius="8"
                Padding="12,8" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Profile:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,12,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="ProfileSelector" Width="200"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="ProfileSelector_Changed"/>
            </StackPanel>
        </Border>

        <!-- Mode toggle -->
        <Border Grid.Row="3" Background="{DynamicResource CardBg}" CornerRadius="8"
                Padding="12,10" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Filter mode:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,12,0" FontWeight="SemiBold"/>
                <RadioButton x:Name="BlockModeRadio" Content="Block list" GroupName="FilterMode"
                             Foreground="{DynamicResource TextPrimary}" IsChecked="True"
                             VerticalAlignment="Center" Margin="0,0,16,0"
                             Checked="Mode_Changed"/>
                <RadioButton x:Name="AllowModeRadio" Content="Allow list (block everything else)" GroupName="FilterMode"
                             Foreground="{DynamicResource TextPrimary}"
                             VerticalAlignment="Center"
                             Checked="Mode_Changed"/>
            </StackPanel>
        </Border>

        <!-- Add domain -->
        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="DomainBox" Grid.Column="0" Height="36"
                     Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                     BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                     Padding="8,4" FontSize="13" Margin="0,0,8,0"
                     VerticalContentAlignment="Center"
                     Tag="Domain (e.g. example.com)"
                     GotFocus="DomainBox_GotFocus" LostFocus="DomainBox_LostFocus"
                     KeyDown="DomainBox_KeyDown"/>
            <Button Grid.Column="1" Content="Add Domain" Height="36" Padding="16,0"
                    Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="AddDomain_Click" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="Remove Selected" Height="36" Padding="16,0"
                    Background="#F38BA8" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="RemoveDomain_Click"/>
        </Grid>

        <!-- Save + sync row -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Save Rules" Height="36" Padding="20,0"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="Save_Click" Margin="0,0,8,0"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
        </StackPanel>

        <!-- Domain list -->
        <Border Grid.Row="6" Background="{DynamicResource CardBg}" CornerRadius="8"
                Padding="0" Margin="0,0,0,0">
            <DataGrid x:Name="DomainsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      CanUserResizeRows="False" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Background="Transparent"
                      RowBackground="{DynamicResource CardBg}"
                      AlternatingRowBackground="{DynamicResource AltRowBg}"
                      Foreground="{DynamicResource TextPrimary}"
                      BorderThickness="0"
                      HorizontalGridLinesBrush="{DynamicResource BorderColor}"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource DataGridRowStyle}"
                      CellStyle="{StaticResource DataGridCellStyle}"
                      SelectionMode="Extended">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Domain / Pattern" Binding="{Binding Pattern}"
                                       Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding ModeLabel}"
                                       Width="120" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
    </ScrollViewer>
</Page>
