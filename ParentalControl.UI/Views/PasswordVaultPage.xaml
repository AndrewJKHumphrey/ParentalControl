<Page x:Class="ParentalControl.UI.Views.PasswordVaultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}" Title="Password Vault">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: heading -->
            <RowDefinition Height="Auto"/>  <!-- 1: description -->
            <RowDefinition Height="Auto"/>  <!-- 2: toolbar -->
            <RowDefinition Height="Auto"/>  <!-- 3: data grid -->
            <RowDefinition Height="Auto"/>  <!-- 4: add-entry form -->
            <RowDefinition Height="Auto"/>  <!-- 5: vault PIN management -->
        </Grid.RowDefinitions>

        <!-- Heading -->
        <TextBlock Grid.Row="0" Text="Password Vault" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>

        <!-- Description -->
        <TextBlock Grid.Row="1"
                   Text="Store and retrieve your children's account credentials securely. Passwords are encrypted using Windows machine-level protection."
                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <!-- Toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="AddEntryBtn" Content="+ Add Entry" Height="36" Padding="16,0"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                    Click="AddEntry_Click"/>
            <Button Content="Open Child Vault" Height="36" Padding="16,0"
                    Background="{DynamicResource CardHover}" Foreground="{DynamicResource TextPrimary}"
                    BorderThickness="0" Cursor="Hand"
                    Click="OpenChildVault_Click"/>
        </StackPanel>

        <!-- Entries grid -->
        <Border Grid.Row="3" Background="{DynamicResource CardBg}" CornerRadius="8"
                Padding="0" Margin="0,0,0,16">
            <DataGrid x:Name="VaultGrid"
                      AutoGenerateColumns="False"
                      Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                      BorderThickness="0" GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource AltRowBg}"
                      MinHeight="60">
                <DataGrid.Columns>

                    <!-- Child profile -->
                    <DataGridTextColumn Header="Child" Binding="{Binding ProfileName}"
                                       Width="120" IsReadOnly="True"/>

                    <!-- Site -->
                    <DataGridTextColumn Header="Site / Service" Binding="{Binding SiteName}"
                                       Width="160" IsReadOnly="True"/>

                    <!-- Username + Copy -->
                    <DataGridTemplateColumn Header="Username" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Username}" VerticalAlignment="Center"
                                               Margin="4,0,8,0"/>
                                    <Button Content="Copy" Height="24" Padding="8,0"
                                            Background="#45475A" Foreground="{DynamicResource TextPrimary}"
                                            BorderThickness="0" Cursor="Hand" FontSize="11"
                                            Tag="{Binding Username}"
                                            Click="CopyUsername_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Password + Show + Copy -->
                    <DataGridTemplateColumn Header="Password" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="••••••••" VerticalAlignment="Center"
                                               Margin="4,0,8,0" Foreground="{DynamicResource TextSecondary}"/>
                                    <Button Content="Show" Height="24" Padding="8,0"
                                            Background="#45475A" Foreground="{DynamicResource TextPrimary}"
                                            BorderThickness="0" Cursor="Hand" FontSize="11"
                                            Tag="{Binding EncryptedPassword}"
                                            Click="ShowPassword_Click" Margin="0,0,4,0"/>
                                    <Button Content="Copy" Height="24" Padding="8,0"
                                            Background="#45475A" Foreground="{DynamicResource TextPrimary}"
                                            BorderThickness="0" Cursor="Hand" FontSize="11"
                                            Tag="{Binding EncryptedPassword}"
                                            Click="CopyPassword_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Delete -->
                    <DataGridTemplateColumn Header="" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Delete" Height="24" Padding="8,0"
                                        Background="#F38BA8" Foreground="#1E1E2E"
                                        BorderThickness="0" Cursor="Hand" FontSize="11" FontWeight="Bold"
                                        Tag="{Binding Id}"
                                        Click="DeleteEntry_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Add-entry form (hidden by default) -->
        <Border x:Name="AddForm" Grid.Row="4" Background="{DynamicResource CardBg}"
                CornerRadius="8" Padding="20" Margin="0,0,0,0"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Form heading -->
                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                           Text="New Entry" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

                <!-- Child profile picker -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Child Profile:"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                           Margin="0,0,0,10"/>
                <ComboBox x:Name="ProfilePicker" Grid.Row="1" Grid.Column="1"
                          DisplayMemberPath="DisplayName" Height="34"
                          Margin="0,0,0,10"/>

                <!-- Site name -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Site / Service:"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                           Margin="0,0,0,10"/>
                <TextBox x:Name="SiteBox" Grid.Row="2" Grid.Column="1" Height="34"
                         Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                         Padding="8,4" Margin="0,0,0,10"/>

                <!-- Username -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Username / Email:"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                           Margin="0,0,0,10"/>
                <TextBox x:Name="UsernameBox" Grid.Row="3" Grid.Column="1" Height="34"
                         Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                         Padding="8,4" Margin="0,0,0,10"/>

                <!-- Password -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Password:"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                    <PasswordBox x:Name="PasswordBox" Height="34" Width="260"
                                 Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                 Padding="8,4" Margin="0,0,12,0"/>
                    <Button Content="Save Entry" Height="34" Padding="16,0"
                            Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                            Click="SaveEntry_Click"/>
                    <Button Content="Cancel" Height="34" Padding="16,0"
                            Background="#45475A" Foreground="{DynamicResource TextPrimary}"
                            BorderThickness="0" Cursor="Hand"
                            Click="CancelAdd_Click"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Vault PIN management -->
        <Border Grid.Row="5" Background="{DynamicResource CardBg}" CornerRadius="8"
                Padding="20" Margin="0,16,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Section heading -->
                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                           Text="Child Vault PIN" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                           Text="Set a numeric PIN (4–8 digits) so a child can view their own passwords in the browser extension without needing the parent password."
                           Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"
                           FontSize="12" Margin="0,0,0,16"/>

                <!-- Profile picker -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Child Profile:"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                           Margin="0,0,0,10"/>
                <ComboBox x:Name="PinProfileSelector" Grid.Row="2" Grid.Column="1"
                          DisplayMemberPath="DisplayName" Height="34" Width="220"
                          HorizontalAlignment="Left" Margin="0,0,0,10"
                          SelectionChanged="PinProfileSelector_Changed"/>

                <!-- PIN entry + buttons + status -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="New PIN:"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <PasswordBox x:Name="PinBox" Height="34" Width="140"
                                 Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                 Padding="8,4" Margin="0,0,10,0" MaxLength="8"/>
                    <Button Content="Set PIN" Height="34" Padding="14,0"
                            Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"
                            Click="SetPin_Click"/>
                    <Button Content="Clear PIN" Height="34" Padding="14,0"
                            Background="#F38BA8" Foreground="#1E1E2E" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,16,0"
                            Click="ClearPin_Click"/>
                    <TextBlock x:Name="PinStatusText" VerticalAlignment="Center"
                               FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
    </ScrollViewer>
</Page>
