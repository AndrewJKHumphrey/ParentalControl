<Page x:Class="ParentalControl.UI.Views.ProfilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}" Title="Profiles">
    <ScrollViewer>
        <StackPanel Margin="32">
            <TextBlock Text="Profiles" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
            <TextBlock Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,24" TextWrapping="Wrap"
                       Text="Profiles are automatically created for each Windows user account found on this machine when the service starts. Edit the Display Name or toggle Enabled to control which accounts are monitored. 'Con. violation checks' keeps re-locking the screen each time the user logs back in after a violation. Accounts without a Windows password always have this enabled and cannot disable it."/>

            <!-- Profiles list -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20">
                <DataGrid x:Name="ProfilesGrid" AutoGenerateColumns="False"
                          Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                          BorderThickness="0" GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column" RowBackground="Transparent"
                          AlternatingRowBackground="{DynamicResource AltRowBg}"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserSortColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="Auto"/>
                        <DataGridTextColumn Header="Windows Username" Binding="{Binding WindowsUsername}"
                                            Width="Auto" IsReadOnly="True"/>
                        <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="80"/>
                        <DataGridTemplateColumn Header="Con. violation checks" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center"
                                              IsChecked="{Binding AlwaysRelock, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding AccountIsPasswordProtected}">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AccountIsPasswordProtected}" Value="False">
                                                        <Setter Property="IsChecked" Value="True"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Button Content="Save Changes" Margin="0,16,0,0" Height="38" Width="160"
                    HorizontalAlignment="Left"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand"
                    Click="SaveButton_Click"/>

            <TextBlock x:Name="StatusText" Foreground="#A6E3A1" Margin="0,10,0,0" Visibility="Collapsed"/>
        </StackPanel>
    </ScrollViewer>
</Page>
