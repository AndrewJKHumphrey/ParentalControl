<Page x:Class="ParentalControl.UI.Views.ProfilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}" Title="Profiles">
    <ScrollViewer>
        <StackPanel Margin="32">
            <TextBlock Text="Profiles" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
            <TextBlock Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,24" TextWrapping="Wrap"
                       Text="Profiles are automatically created for each Windows user account found on this machine when the service starts. Edit the Display Name, toggle Enabled, or mark whether the child's account is protected by a Windows password (when enabled, the service only locks once per violation since the password prevents re-entry without a parent)."/>

            <!-- Profiles list -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20">
                <DataGrid x:Name="ProfilesGrid" AutoGenerateColumns="False"
                          Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                          BorderThickness="0" GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column" RowBackground="Transparent"
                          AlternatingRowBackground="{DynamicResource AltRowBg}"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserSortColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="200"/>
                        <DataGridTextColumn Header="Windows Username" Binding="{Binding WindowsUsername}"
                                            Width="200" IsReadOnly="True"/>
                        <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="80"/>
                        <DataGridCheckBoxColumn Header="Has Password" Binding="{Binding ChildAccountHasPassword}"
                                                Width="110"
                                                ToolTipService.ToolTip="Enable if this child account has a Windows password — the service will only lock once per violation since the password prevents unsupervised re-entry."/>
                        <DataGridTemplateColumn Header="Remove" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Remove" Tag="{Binding Id}"
                                            Background="#F38BA8" Foreground="#1E1E2E"
                                            FontSize="11" FontWeight="Bold" BorderThickness="0"
                                            Cursor="Hand" Padding="6,3"
                                            Click="DeleteProfile_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Button Content="Save Changes" Margin="0,16,0,0" Height="38" Width="160"
                    HorizontalAlignment="Left"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand"
                    Click="SaveButton_Click"/>

            <TextBlock x:Name="StatusText" Foreground="#A6E3A1" Margin="0,10,0,0" Visibility="Collapsed"/>
        </StackPanel>
    </ScrollViewer>
</Page>
