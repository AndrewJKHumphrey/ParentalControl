<Page x:Class="ParentalControl.UI.Views.ProfilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}" Title="Profiles">
    <ScrollViewer>
        <StackPanel Margin="32">
            <TextBlock Text="Profiles" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
            <TextBlock Text="Create a profile for each Windows user account on this machine. The service enforces that profile's rules when that user is logged in. Leave Windows Username blank to create a catch-all default profile."
                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,24" TextWrapping="Wrap"/>

            <!-- Add profile -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Add Profile" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>
                    <WrapPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                            <TextBlock Text="Display Name:" VerticalAlignment="Center" Width="120"
                                       Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox x:Name="DisplayNameBox" Width="200" Height="32"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,8">
                            <TextBlock Text="Windows Username:" VerticalAlignment="Center" Width="140"
                                       Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox x:Name="UsernameBox" Width="200" Height="32"/>
                        </StackPanel>
                        <Button Content="Add Profile" Height="32" Width="110" Margin="0,0,0,8"
                                Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand"
                                Click="AddProfile_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Profiles list -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20">
                <DataGrid x:Name="ProfilesGrid" AutoGenerateColumns="False"
                          Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                          BorderThickness="0" GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column" RowBackground="Transparent"
                          AlternatingRowBackground="{DynamicResource AltRowBg}"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserSortColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="180"/>
                        <DataGridTextColumn Header="Windows Username" Binding="{Binding WindowsUsername}" Width="200"/>
                        <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="80"/>
                        <DataGridTemplateColumn Header="Remove" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Remove" Tag="{Binding Id}"
                                            Background="#F38BA8" Foreground="#1E1E2E"
                                            FontSize="11" FontWeight="Bold" BorderThickness="0"
                                            Cursor="Hand" Padding="6,3"
                                            Click="DeleteProfile_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Button Content="Save Changes" Margin="0,16,0,0" Height="38" Width="160"
                    HorizontalAlignment="Left"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand"
                    Click="SaveButton_Click"/>

            <TextBlock x:Name="StatusText" Foreground="#A6E3A1" Margin="0,10,0,0" Visibility="Collapsed"/>
        </StackPanel>
    </ScrollViewer>
</Page>
