<Window x:Class="ParentalControl.UI.Views.TagDomainViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Domain Viewer" Height="560" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource AppBg}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: tag name header -->
            <RowDefinition Height="Auto"/>  <!-- 1: search box -->
            <RowDefinition Height="Auto"/>  <!-- 2: count label -->
            <RowDefinition Height="*"/>     <!-- 3: domain list -->
            <RowDefinition Height="Auto"/>  <!-- 4: hint + close button -->
        </Grid.RowDefinitions>

        <!-- Tag name -->
        <TextBlock x:Name="TagNameLabel" Grid.Row="0"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

        <!-- Search box -->
        <TextBox x:Name="SearchBox" Grid.Row="1"
                 Height="34" Padding="8,4" FontSize="13"
                 Background="{DynamicResource CardBg}"
                 Foreground="{DynamicResource TextPrimary}"
                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                 VerticalContentAlignment="Center"
                 Margin="0,0,0,6"
                 TextChanged="SearchBox_TextChanged"/>

        <!-- Count label -->
        <TextBlock x:Name="CountLabel" Grid.Row="2"
                   Foreground="{DynamicResource TextSecondary}" FontSize="12"
                   Margin="0,0,0,6"/>

        <!-- Domain list -->
        <Border Grid.Row="3" Background="{DynamicResource CardBg}"
                CornerRadius="6" Padding="0" Margin="0,0,0,12">
            <ListBox x:Name="DomainListBox"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="12" Padding="4,2"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>

        <!-- Hint + close -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Domain not listed? Add it in the Block / Allow section."
                       Foreground="{DynamicResource TextSecondary}" FontSize="11"
                       VerticalAlignment="Center" TextWrapping="Wrap"/>
            <Button Grid.Column="1" Content="Close" Height="34" Padding="20,0"
                    Background="{DynamicResource CardBg}"
                    Foreground="{DynamicResource TextPrimary}"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                    Cursor="Hand" Click="Close_Click" Margin="12,0,0,0"/>
        </Grid>
    </Grid>
</Window>
