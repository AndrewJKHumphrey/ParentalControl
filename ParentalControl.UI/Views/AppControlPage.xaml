<Page x:Class="ParentalControl.UI.Views.AppControlPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}" Title="App Control">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="App Control" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,20" TextWrapping="Wrap"
                   Text="Manage application access per profile. Set each app to Unrestricted, Allowed during app time, or Blocked. Check 'Focus Mode' to allow an app during focus hours."/>

        <!-- Profile selector -->
        <Border Grid.Row="2" Background="{DynamicResource CardBg}" CornerRadius="8"
                Padding="12,8" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Profile:" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,12,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="ProfileSelector" Width="200"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="ProfileSelector_Changed"/>
            </StackPanel>
        </Border>

        <!-- Add new rule -->
        <Grid Grid.Row="4" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Display Name" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="DisplayNameBox" Height="36"
                         Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                         Padding="8,4" FontSize="13"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                <TextBlock Text="Process Name (e.g. chrome.exe, notepad.exe)" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="ProcessNameBox" Height="36"
                         Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                         Padding="8,4" FontSize="13"/>
            </StackPanel>
            <Button Grid.Column="2" Content="Add Rule" Height="36" Padding="16,0"
                    VerticalAlignment="Bottom"
                    Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="AddRule_Click"/>
        </Grid>

        <!-- Game scan -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
            <TextBlock Text="Drive:" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,8,0"/>
            <ComboBox x:Name="DriveSelector" Width="100" Height="36" Margin="0,0,8,0"
                      VerticalContentAlignment="Center"/>
            <Button x:Name="ScanButton" Content="Scan for Games" Height="36" Padding="16,0"
                    Background="#CBA6F7" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="ScanGames_Click"
                    ToolTip="Scan selected drive for games from Steam, GOG, Epic, EA, Battle.net, and Ubisoft Connect"/>
            <TextBlock x:Name="ScanStatusText" VerticalAlignment="Center" Margin="12,0,0,0"
                       Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- App Time Schedule (per-day) -->
        <Border Grid.Row="3" Background="{DynamicResource CardBg}" CornerRadius="8"
                Padding="8" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Daily App Time Schedule" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" Margin="8,8,8,4"/>
                <TextBlock Text="Enable a day and set its minute limit for 'Allowed during app time' apps. Disabled days have no app time limit."
                           Foreground="{DynamicResource TextSecondary}" FontSize="12"
                           Margin="8,0,8,8" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,8,8">
                    <TextBlock Text="Apply to:" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,12,0"/>
                    <ComboBox x:Name="DayRangeBox" Width="140"
                              SelectionChanged="DayRangeBox_Changed">
                        <ComboBoxItem Content="Single Day" IsSelected="True"/>
                        <ComboBoxItem Content="Weekdays"/>
                        <ComboBoxItem Content="Weekends"/>
                        <ComboBoxItem Content="Everyday"/>
                    </ComboBox>
                </StackPanel>
                <DataGrid x:Name="AppTimeScheduleGrid" AutoGenerateColumns="False"
                          Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                          BorderThickness="0" GridLinesVisibility="None"
                          HeadersVisibility="Column" IsReadOnly="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          RowBackground="Transparent" AlternatingRowBackground="{DynamicResource AltRowBg}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Day" Binding="{Binding DayLabel}" IsReadOnly="True" Width="110"/>
                        <DataGridTemplateColumn Header="Enabled" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Daily Limit (minutes)" Binding="{Binding DailyLimitMinutes}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- Rules list -->
        <Border Grid.Row="6" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="8"
                MaxHeight="450">
            <DataGrid x:Name="AppRulesGrid" AutoGenerateColumns="False"
                      Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                      BorderThickness="0" GridLinesVisibility="None"
                      HeadersVisibility="Column" IsReadOnly="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      RowBackground="Transparent" AlternatingRowBackground="{DynamicResource AltRowBg}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="*"/>
                    <DataGridTextColumn Header="Process Name" Binding="{Binding ProcessName}" Width="*"/>
                    <DataGridTextColumn Header="Rating" Binding="{Binding EsrbRating}" IsReadOnly="True" Width="60"/>
                    <DataGridTextColumn Header="Genres" Binding="{Binding Genres}" IsReadOnly="True" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="ToolTip" Value="{Binding Tags}"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Access mode -->
                    <DataGridTemplateColumn Header="Access" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox SelectedIndex="{Binding AccessMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Background="{DynamicResource CardBg}"
                                          Foreground="{DynamicResource TextPrimary}"
                                          BorderThickness="0" Padding="4,2" VerticalAlignment="Center">
                                    <ComboBoxItem Content="Unrestricted"/>
                                    <ComboBoxItem Content="Allowed during app time"/>
                                    <ComboBoxItem Content="Blocked"/>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Focus Mode allowed checkbox -->
                    <DataGridTemplateColumn Header="Focus Mode" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding AllowedInFocusMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          ToolTip="Allow this app to run during Focus Mode hours"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Remove row -->
                    <DataGridTemplateColumn Header="Remove" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" Width="30" Height="24"
                                        Background="#F38BA8" Foreground="#1E1E2E"
                                        FontWeight="Bold" BorderThickness="0"
                                        Tag="{Binding Id}"
                                        Click="DeleteRule_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <WrapPanel Grid.Row="7" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Save for Current Profile" Height="38" Width="220"
                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,12,0"
                    Click="SaveButton_Click"/>
            <Button Content="Save to All Profiles" Height="38" Width="180"
                    Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand"
                    Click="SaveToAllButton_Click"/>
        </WrapPanel>
    </Grid>
    </ScrollViewer>
</Page>
