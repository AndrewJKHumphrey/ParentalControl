<Page x:Class="ParentalControl.UI.Views.AppControlPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}" Title="App Control">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="App Control" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,20" TextWrapping="Wrap"
                   Text="Block specific applications. Enter the process name (e.g. chrome, notepad) and toggle blocking."/>

        <!-- Add new rule -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Display Name" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="DisplayNameBox" Height="36"
                         Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                         Padding="8,4" FontSize="13"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                <TextBlock Text="Process Name (e.g. chrome, notepad)" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="ProcessNameBox" Height="36"
                         Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                         Padding="8,4" FontSize="13"/>
            </StackPanel>
            <Button Grid.Column="2" Content="Add Rule" Height="36" Padding="16,0"
                    VerticalAlignment="Bottom"
                    Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="AddRule_Click"/>
        </Grid>

        <!-- Steam scan -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
            <Button x:Name="QuickScanButton" Content="Quick Scan (Steam)" Height="36" Padding="16,0"
                    Background="#CBA6F7" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="QuickScanSteam_Click"
                    ToolTip="Scans the default Steam library and any libraries registered in Steam"/>
            <Button x:Name="DeepScanButton" Content="Deep Scan (All Drives)" Height="36" Padding="16,0"
                    Margin="8,0,0,0"
                    Background="#89DCEB" Foreground="#1E1E2E" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="DeepScanSteam_Click"
                    ToolTip="Searches every drive for Steam game folders — may take a moment"/>
            <TextBlock x:Name="ScanStatusText" VerticalAlignment="Center" Margin="12,0,0,0"
                       Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- Rules list -->
        <Border Grid.Row="4" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="8">
            <DataGrid x:Name="AppRulesGrid" AutoGenerateColumns="False"
                      Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                      BorderThickness="0" GridLinesVisibility="None"
                      HeadersVisibility="Column" IsReadOnly="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      RowBackground="Transparent" AlternatingRowBackground="{DynamicResource AltRowBg}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="*"/>
                    <DataGridTextColumn Header="Process Name" Binding="{Binding ProcessName}" Width="*"/>
                    <DataGridCheckBoxColumn Header="Blocked" Binding="{Binding IsBlocked}" Width="80"/>
                    <DataGridTemplateColumn Header="Remove" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" Width="30" Height="24"
                                        Background="#F38BA8" Foreground="#1E1E2E"
                                        FontWeight="Bold" BorderThickness="0"
                                        Tag="{Binding Id}"
                                        Click="DeleteRule_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            
        </Border>
        
        <Button Grid.Row="5" Content="Save Changes" Margin="0,12,0,0" Height="38" Width="160"
                HorizontalAlignment="Left"
                Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                BorderThickness="0" Cursor="Hand"
                Click="SaveButton_Click"/>
    </Grid>
</Page>
