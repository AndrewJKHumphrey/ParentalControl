<Page x:Class="ParentalControl.UI.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E" Title="Dashboard">
    <ScrollViewer>
        <StackPanel Margin="32">
            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold"
                       Foreground="#CDD6F4" Margin="0,0,0,24"/>

            <!-- Stats row -->
            <WrapPanel>
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="Screen Time Today" Foreground="#A6ADC8" FontSize="12"/>
                        <TextBlock x:Name="ScreenTimeText" Text="-- min" Foreground="#89B4FA"
                                   FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="Apps Blocked Today" Foreground="#A6ADC8" FontSize="12"/>
                        <TextBlock x:Name="AppsBlockedText" Text="--" Foreground="#F38BA8"
                                   FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="Websites Blocked" Foreground="#A6ADC8" FontSize="12"/>
                        <TextBlock x:Name="WebsitesBlockedText" Text="--" Foreground="#FAB387"
                                   FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="Service Status" Foreground="#A6ADC8" FontSize="12"/>
                        <TextBlock x:Name="ServiceStatusText" Text="Checking..." Foreground="#A6E3A1"
                                   FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Recent activity -->
            <TextBlock Text="Recent Activity" FontSize="18" FontWeight="SemiBold"
                       Foreground="#CDD6F4" Margin="0,32,0,12"/>

            <Border Background="#313244" CornerRadius="8" Padding="16">
                <DataGrid x:Name="RecentGrid" AutoGenerateColumns="False"
                          Background="Transparent" Foreground="#CDD6F4"
                          BorderThickness="0" GridLinesVisibility="None"
                          HeadersVisibility="Column" IsReadOnly="True"
                          RowBackground="Transparent" AlternatingRowBackground="#2A2A3E"
                          MaxHeight="300">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" Width="90"/>
                        <DataGridTextColumn Header="Event" Binding="{Binding Type}" Width="160"/>
                        <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
