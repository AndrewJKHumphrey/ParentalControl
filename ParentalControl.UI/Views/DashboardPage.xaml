<Page x:Class="ParentalControl.UI.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}" Title="Dashboard">
    <ScrollViewer>
        <StackPanel Margin="24,20,24,20">
            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

            <WrapPanel Margin="0,0,0,8">
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="Active Profile" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                        <TextBlock x:Name="ActiveProfileText" Text="--"
                                   Foreground="#CBA6F7" FontSize="20" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
            <!-- ── Screen Time ─────────────────────────────────────────────── -->
            <TextBlock Text="Screen Time" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
            <StackPanel Margin="0,0,0,8">
                <!-- Daily usage group -->
                <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="8,4" Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="Screen Time Today" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                <TextBlock x:Name="ScreenTimeText" Text="-- min" Foreground="#89B4FA"
                                           FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="Time Allowed Today" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                <TextBlock x:Name="ScreenTimeLimitText" Text="--"
                                           Foreground="#CBA6F7" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="Time Remaining Today" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                <TextBlock x:Name="TimeRemainingText" Text="--"
                                           FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Padding="10,6">
                            <StackPanel>
                                <TextBlock Text="Adjust Screen Time for today" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="ExtendMinutesBox" Grid.Column="0" Height="28" SelectedIndex="12" Margin="0,0,4,0">
                                        <ComboBoxItem Content="-60"/>
                                        <ComboBoxItem Content="-55"/>
                                        <ComboBoxItem Content="-50"/>
                                        <ComboBoxItem Content="-45"/>
                                        <ComboBoxItem Content="-40"/>
                                        <ComboBoxItem Content="-35"/>
                                        <ComboBoxItem Content="-30"/>
                                        <ComboBoxItem Content="-25"/>
                                        <ComboBoxItem Content="-20"/>
                                        <ComboBoxItem Content="-15"/>
                                        <ComboBoxItem Content="-10"/>
                                        <ComboBoxItem Content="-5"/>
                                        <ComboBoxItem Content="0"/>
                                        <ComboBoxItem Content="5"/>
                                        <ComboBoxItem Content="10"/>
                                        <ComboBoxItem Content="15"/>
                                        <ComboBoxItem Content="20"/>
                                        <ComboBoxItem Content="25"/>
                                        <ComboBoxItem Content="30"/>
                                        <ComboBoxItem Content="35"/>
                                        <ComboBoxItem Content="40"/>
                                        <ComboBoxItem Content="45"/>
                                        <ComboBoxItem Content="50"/>
                                        <ComboBoxItem Content="55"/>
                                        <ComboBoxItem Content="60"/>
                                    </ComboBox>
                                    <Button x:Name="ResetScreenTimeButton" Grid.Column="1" Content="Adjust Time" Height="28" Padding="10,0"
                                            Background="#F38BA8" Foreground="#1E1E2E" FontWeight="Bold"
                                            BorderThickness="0" Cursor="Hand" Click="ResetScreenTime_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                <!-- Allowed range group -->
                <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="8,4" Margin="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="Allowed Time Range" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                <TextBlock x:Name="AllowedRangeText" Text="--:-- – --:--" Foreground="#A6E3A1"
                                           FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="Time Until Window Begins" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                <TextBlock x:Name="AllowedRangeStartText" Text="--"
                                           FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="Time Until Window Ends" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                <TextBlock x:Name="AllowedRangeRemainingText" Text="--"
                                           FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Padding="10,6">
                            <StackPanel>
                                <TextBlock Text="Adjust allowed time range" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="ExtendRangeBox" Grid.Column="0" Height="28" SelectedIndex="12" Margin="0,0,4,0">
                                        <ComboBoxItem Content="-60"/>
                                        <ComboBoxItem Content="-55"/>
                                        <ComboBoxItem Content="-50"/>
                                        <ComboBoxItem Content="-45"/>
                                        <ComboBoxItem Content="-40"/>
                                        <ComboBoxItem Content="-35"/>
                                        <ComboBoxItem Content="-30"/>
                                        <ComboBoxItem Content="-25"/>
                                        <ComboBoxItem Content="-20"/>
                                        <ComboBoxItem Content="-15"/>
                                        <ComboBoxItem Content="-10"/>
                                        <ComboBoxItem Content="-5"/>
                                        <ComboBoxItem Content="0"/>
                                        <ComboBoxItem Content="5"/>
                                        <ComboBoxItem Content="10"/>
                                        <ComboBoxItem Content="15"/>
                                        <ComboBoxItem Content="20"/>
                                        <ComboBoxItem Content="25"/>
                                        <ComboBoxItem Content="30"/>
                                        <ComboBoxItem Content="35"/>
                                        <ComboBoxItem Content="40"/>
                                        <ComboBoxItem Content="45"/>
                                        <ComboBoxItem Content="50"/>
                                        <ComboBoxItem Content="55"/>
                                        <ComboBoxItem Content="60"/>
                                    </ComboBox>
                                    <Button x:Name="ExtendRangeButton" Grid.Column="1" Content="Adjust Time" Height="28" Padding="10,0"
                                            Background="#F38BA8" Foreground="#1E1E2E" FontWeight="Bold"
                                            BorderThickness="0" Cursor="Hand" Click="ExtendRange_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ── App Control ────────────────────────────────────────────── -->
            <TextBlock Text="App Control" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="4,4" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Padding="10,6">
                        <StackPanel>
                            <TextBlock Text="Apps Blocked Today" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock x:Name="AppsBlockedText" Text="--" Foreground="#F38BA8"
                                       FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="10,6">
                        <StackPanel>
                            <TextBlock Text="App Time Used Today" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock x:Name="AppTimeUsedText" Text="-- min" Foreground="#FAB387"
                                       FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="10,6">
                        <StackPanel>
                            <TextBlock Text="App Time Remaining" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <TextBlock x:Name="AppTimeRemainingText" Text="--"
                                       FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Padding="10,6">
                        <StackPanel>
                            <TextBlock Text="Adjust App Time for today" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="ExtendAppTimeBox" Grid.Column="0" Height="28" SelectedIndex="12" Margin="0,0,4,0">
                                    <ComboBoxItem Content="-60"/>
                                    <ComboBoxItem Content="-55"/>
                                    <ComboBoxItem Content="-50"/>
                                    <ComboBoxItem Content="-45"/>
                                    <ComboBoxItem Content="-40"/>
                                    <ComboBoxItem Content="-35"/>
                                    <ComboBoxItem Content="-30"/>
                                    <ComboBoxItem Content="-25"/>
                                    <ComboBoxItem Content="-20"/>
                                    <ComboBoxItem Content="-15"/>
                                    <ComboBoxItem Content="-10"/>
                                    <ComboBoxItem Content="-5"/>
                                    <ComboBoxItem Content="0"/>
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="15"/>
                                    <ComboBoxItem Content="20"/>
                                    <ComboBoxItem Content="25"/>
                                    <ComboBoxItem Content="30"/>
                                    <ComboBoxItem Content="35"/>
                                    <ComboBoxItem Content="40"/>
                                    <ComboBoxItem Content="45"/>
                                    <ComboBoxItem Content="50"/>
                                    <ComboBoxItem Content="55"/>
                                    <ComboBoxItem Content="60"/>
                                </ComboBox>
                                <Button x:Name="ExtendAppTimeButton" Grid.Column="1" Content="Adjust Time" Height="28" Padding="10,0"
                                        Background="#F38BA8" Foreground="#1E1E2E" FontWeight="Bold"
                                        BorderThickness="0" Cursor="Hand" Click="ExtendAppTime_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Focus Mode ─────────────────────────────────────────────── -->
            <TextBlock Text="Focus Mode" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
            <WrapPanel Margin="0,0,0,8">
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="Focus Mode Status" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                        <TextBlock x:Name="FocusModeStatusText" Text="--"
                                   FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                        <TextBlock x:Name="FocusModeWindowText" Text="" Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- ── Web Filter ─────────────────────────────────────────────── -->
            <TextBlock Text="Web Filter" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
            <WrapPanel Margin="0,0,0,16">
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="Websites Blocked Today" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                        <TextBlock x:Name="WebsitesBlockedText" Text="--" Foreground="#FAB387"
                                   FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- Enforcement toggles -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="16,10" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Enforcement" Foreground="{DynamicResource TextPrimary}"
                               FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>
                    <WrapPanel>
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="Admin Mode (Toggle All Enforcement)"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Off" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                                <CheckBox x:Name="AdminToggle" Style="{StaticResource ToggleSwitch}"
                                          Checked="AdminToggle_Changed" Unchecked="AdminToggle_Changed"/>
                                <TextBlock Text="On" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="Screen Time"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Off" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                                <CheckBox x:Name="ScreenTimeToggle" Style="{StaticResource ToggleSwitch}"
                                          Checked="Enforcement_Changed" Unchecked="Enforcement_Changed"/>
                                <TextBlock Text="On" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="App Control"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Off" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                                <CheckBox x:Name="AppControlToggle" Style="{StaticResource ToggleSwitch}"
                                          Checked="Enforcement_Changed" Unchecked="Enforcement_Changed"/>
                                <TextBlock Text="On" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="Focus Mode"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Off" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                                <CheckBox x:Name="FocusModeToggle" Style="{StaticResource ToggleSwitch}"
                                          Checked="Enforcement_Changed" Unchecked="Enforcement_Changed"/>
                                <TextBlock Text="On" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="Website Filter"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Off" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                                <CheckBox x:Name="WebFilterToggle" Style="{StaticResource ToggleSwitch}"
                                          Checked="Enforcement_Changed" Unchecked="Enforcement_Changed"/>
                                <TextBlock Text="On" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Recent activity -->
            <TextBlock Text="Recent Activity" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,8,0,8"/>

            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="16">
                <DataGrid x:Name="RecentGrid" AutoGenerateColumns="False"
                          Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                          BorderThickness="0" GridLinesVisibility="None"
                          HeadersVisibility="Column" IsReadOnly="True"
                          RowBackground="Transparent" AlternatingRowBackground="{DynamicResource AltRowBg}"
                          MaxHeight="300">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" Width="90"/>
                        <DataGridTextColumn Header="Event" Binding="{Binding Type}" Width="160"/>
                        <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
