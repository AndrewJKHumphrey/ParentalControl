<Window x:Class="ParentalControl.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parental Control - Login" Height="280" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource AppBg}">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="&#x1F512; Parental Control" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Enter parent password:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>

        <PasswordBox x:Name="PasswordBox" Grid.Row="2" Height="36"
                     FontSize="14" Padding="8,4"
                     Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                     BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                     KeyDown="PasswordBox_KeyDown"/>

        <TextBlock x:Name="ErrorText" Grid.Row="3" Foreground="#F38BA8"
                   Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

        <Button Grid.Row="4" Content="Unlock" Height="38" Margin="0,16,0,0"
                Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold" FontSize="14"
                BorderThickness="0" Cursor="Hand"
                Click="LoginButton_Click"/>
    </Grid>
</Window>
