<Page x:Class="ParentalControl.UI.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource AppBg}" Title="Settings">
    <ScrollViewer>
        <StackPanel Margin="32" MaxWidth="500">
            <TextBlock Text="Settings" FontSize="24" FontWeight="Bold"

                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,32"/>
            <!-- Time format toggle -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Time format:" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="24H (0000-2359)" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                    <CheckBox x:Name="Format12hToggle" Style="{StaticResource ToggleSwitch}"
                            Checked="TimeFormat_Changed" Unchecked="TimeFormat_Changed"/>
                    <TextBlock Text="12H (AM/PM)" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Change password -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Change Parent Password" Foreground="{DynamicResource TextPrimary}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <TextBlock Text="Current password:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="CurrentPasswordBox" Height="36" Margin="0,0,0,12"
                                 Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="8,4"/>

                    <TextBlock Text="New password:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="NewPasswordBox" Height="36" Margin="0,0,0,12"
                                 Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="8,4"/>

                    <TextBlock Text="Confirm new password:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Height="36" Margin="0,0,0,16"
                                 Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="8,4"/>

                    <Button Content="Change Password" Height="36" Width="180" HorizontalAlignment="Left"
                            Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand" Click="ChangePassword_Click"/>

                    <TextBlock x:Name="PwdStatus" Margin="0,10,0,0" TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Notifications (hidden until UX is finalised) -->
            <Border Visibility="Collapsed" Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Notifications" Foreground="{DynamicResource TextPrimary}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <!-- Master toggle -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="Off" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                        <CheckBox x:Name="NotificationsEnabledToggle" Style="{StaticResource ToggleSwitch}"
                                  Checked="Notifications_Changed" Unchecked="Notifications_Changed"/>
                        <TextBlock Text="On" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13"/>
                    </StackPanel>

                    <!-- Delivery mode -->
                    <TextBlock Text="Notify via:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <RadioButton x:Name="ModeEmailRadio" Content="Email" GroupName="NotifyMode"
                                     Foreground="{DynamicResource TextPrimary}" Margin="0,0,20,0"
                                     Checked="NotifyMode_Changed"/>
                        <RadioButton x:Name="ModeTextRadio" Content="Text message" GroupName="NotifyMode"
                                     Foreground="{DynamicResource TextPrimary}" Margin="0,0,20,0"
                                     Checked="NotifyMode_Changed"/>
                        <RadioButton x:Name="ModePushRadio" Content="Push notification (ntfy.sh)" GroupName="NotifyMode"
                                     Foreground="{DynamicResource TextPrimary}"
                                     Checked="NotifyMode_Changed"/>
                    </StackPanel>

                    <!-- Email destination -->
                    <StackPanel x:Name="EmailDestPanel" Margin="0,0,0,16">
                        <TextBlock Text="Recipient email address:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <TextBox x:Name="NotificationAddressBox" Height="36"
                                 Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="8,4"
                                 LostFocus="NotificationAddress_LostFocus"/>
                    </StackPanel>

                    <!-- Text message destination -->
                    <StackPanel x:Name="TextDestPanel" Visibility="Collapsed" Margin="0,0,0,16">
                        <TextBlock Text="Phone number (10 digits, no spaces or dashes):" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <TextBox x:Name="PhoneNumberBox" Height="36"
                                 Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="8,4"
                                 LostFocus="PhoneNumber_LostFocus"/>
                        <TextBlock Text="Carrier:" Foreground="{DynamicResource TextSecondary}" Margin="0,8,0,4"/>
                        <ComboBox x:Name="CarrierBox" Height="36" HorizontalAlignment="Left" MinWidth="220"
                                  SelectionChanged="Carrier_SelectionChanged">
                            <ComboBoxItem Content="Verizon"           Tag="vtext.com"/>
                            <ComboBoxItem Content="T-Mobile"          Tag="tmomail.net"/>
                            <ComboBoxItem Content="US Cellular"       Tag="email.uscc.net"/>
                            <ComboBoxItem Content="Cricket Wireless"  Tag="sms.cricketwireless.net"/>
                            <ComboBoxItem Content="Boost Mobile"      Tag="sms.myboostmobile.com"/>
                            <ComboBoxItem Content="Metro by T-Mobile" Tag="mymetropcs.com"/>
                            <ComboBoxItem Content="Google Fi"         Tag="msg.fi.google.com"/>
                            <ComboBoxItem Content="Republic Wireless" Tag="text.republicwireless.com"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Push (ntfy.sh) destination -->
                    <StackPanel x:Name="NtfyDestPanel" Visibility="Collapsed" Margin="0,0,0,16">
                        <TextBlock Text="Topic name (any unique string — share it with no one):"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                        <TextBox x:Name="NtfyTopicBox" Height="36"
                                 Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="8,4"
                                 LostFocus="NtfyTopic_LostFocus"/>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                   Margin="0,6,0,0"
                                   Text="Install the free ntfy app on your phone (ntfy.sh), tap '+' and subscribe to this topic. You'll receive a push notification whenever ParentGuard sends an alert — no account or password needed."/>
                    </StackPanel>

                    <!-- Separator + Sending account (hidden in Push mode) -->
                    <StackPanel x:Name="SendingAccountPanel">
                    <Rectangle Height="1" Fill="{DynamicResource BorderColor}" Margin="0,0,0,16"/>

                    <!-- Sending account -->
                    <TextBlock Text="Sending Account" Foreground="{DynamicResource TextPrimary}"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <TextBlock Text="Your email address (used to send the notification):" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="SmtpUsernameBox" Height="36" Margin="0,0,0,4"
                             Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="8,4"
                             LostFocus="SmtpEmail_LostFocus"/>
                    <TextBlock x:Name="SmtpAutoDetectHint" Foreground="#A6E3A1" FontSize="11"
                               Margin="0,0,0,8" Visibility="Collapsed" TextWrapping="Wrap"/>

                    <TextBlock Text="Password / App Password:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="SmtpPasswordBox" Height="36" Margin="0,0,0,4"
                                 Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="8,4"
                                 LostFocus="SmtpPassword_LostFocus"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,12"
                               Text="Gmail and Yahoo require an App Password — search 'Gmail App Password' or 'Yahoo App Password' to create one. Outlook works with your regular password."/>

                    <!-- Advanced SMTP (hidden by default) -->
                    <Expander Header="Advanced SMTP Settings" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,16">
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="SMTP Server:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="SmtpHostBox" Height="36" Margin="0,0,0,8"
                                     Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextPrimary}"
                                     BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="8,4"
                                     LostFocus="AdvancedSmtp_Changed"/>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="Port:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="SmtpPortBox" Width="80" Height="36"
                                             Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextPrimary}"
                                             BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="8,4"
                                             LostFocus="AdvancedSmtp_Changed"/>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom">
                                    <TextBlock Text="SSL/TLS" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Off" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                                        <CheckBox x:Name="SmtpSslToggle" Style="{StaticResource ToggleSwitch}"
                                                  Checked="AdvancedSmtp_Changed" Unchecked="AdvancedSmtp_Changed"/>
                                        <TextBlock Text="On" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Expander>
                    </StackPanel><!-- /SendingAccountPanel -->

                    <!-- Separator -->
                    <Rectangle Height="1" Fill="{DynamicResource BorderColor}" Margin="0,0,0,16"/>

                    <!-- Per-event toggles -->
                    <TextBlock Text="Notify when:" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="NotifyScreenLockToggle" Style="{StaticResource ToggleSwitch}"
                                  Checked="Notifications_Changed" Unchecked="Notifications_Changed" Margin="0,0,10,0"/>
                        <TextBlock Text="Screen is locked (time limit or outside allowed hours)"
                                   Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <CheckBox x:Name="NotifyAppBlockToggle" Style="{StaticResource ToggleSwitch}"
                                  Checked="Notifications_Changed" Unchecked="Notifications_Changed" Margin="0,0,10,0"/>
                        <TextBlock Text="App is blocked or app time limit reached"
                                   Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Test button -->
                    <Button x:Name="TestNotificationButton" Content="Send Test Notification" Width="200" Height="36" HorizontalAlignment="Left"
                            Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand" Click="TestNotification_Click"/>
                    <TextBlock x:Name="NotificationStatus" Margin="0,10,0,0" Visibility="Collapsed"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Appearance -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Appearance" Foreground="{DynamicResource TextPrimary}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <TextBlock Text="Theme:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,8"/>
                    <ComboBox x:Name="ThemeBox" Width="200" Height="32" HorizontalAlignment="Left"
                              SelectionChanged="ThemeBox_SelectionChanged" Margin="0,0,0,16">

                        <!-- ── Single-colour ─────────────────────────────────────────── -->
                        <ComboBoxItem Content="Default"/>
                        <!-- DEBUG only — hidden in Release builds via code-behind -->
                        <ComboBoxItem x:Name="DebugThemeItem" Content="Dev Mode" Visibility="Collapsed"/>
                        <!-- Red → Rose spectrum -->
                        <ComboBoxItem Content="Red"/>
                        <ComboBoxItem Content="Scarlet"/>
                        <ComboBoxItem Content="Vermilion"/>
                        <ComboBoxItem Content="Orange"/>
                        <ComboBoxItem Content="Amber"/>
                        <ComboBoxItem Content="Yellow"/>
                        <ComboBoxItem Content="Chartreuse"/>
                        <ComboBoxItem Content="Lime"/>
                        <ComboBoxItem Content="Green"/>
                        <ComboBoxItem Content="Teal"/>
                        <ComboBoxItem Content="Cyan"/>
                        <ComboBoxItem Content="Blue"/>
                        <ComboBoxItem Content="Indigo"/>
                        <ComboBoxItem Content="Violet"/>
                        <ComboBoxItem Content="Purple"/>
                        <ComboBoxItem Content="Magenta"/>
                        <ComboBoxItem Content="Rose"/>

                        <!-- ── Two-colour  (sorted by background hue) ────────────────── -->
                        <!-- Red bg -->
                        <ComboBoxItem Content="Volcanic"/>
                        <ComboBoxItem Content="Gothic"/>
                        <ComboBoxItem Content="Midnight Rose"/>
                        <ComboBoxItem Content="Rosewood"/>
                        <!-- Red-Orange bg -->
                        <ComboBoxItem Content="Autumn"/>
                        <ComboBoxItem Content="Wildfire"/>
                        <!-- Orange / Brown bg -->
                        <ComboBoxItem Content="Copper Patina"/>
                        <ComboBoxItem Content="Desert"/>
                        <ComboBoxItem Content="Volcanic Ash"/>
                        <ComboBoxItem Content="Espresso"/>
                        <ComboBoxItem Content="Steampunk"/>
                        <ComboBoxItem Content="Parchment"/>
                        <ComboBoxItem Content="Antique"/>
                        <!-- Amber / Yellow-Orange bg -->
                        <ComboBoxItem Content="CRT Amber"/>
                        <ComboBoxItem Content="Solstice"/>
                        <ComboBoxItem Content="Gruvbox"/>
                        <!-- Yellow-Green bg -->
                        <ComboBoxItem Content="Cherry Grove"/>
                        <!-- Green bg -->
                        <ComboBoxItem Content="Forest Fire"/>
                        <ComboBoxItem Content="Rainforest"/>
                        <ComboBoxItem Content="CRT Green"/>
                        <ComboBoxItem Content="Lagoon"/>
                        <ComboBoxItem Content="Spring"/>
                        <!-- Teal / Cyan bg -->
                        <ComboBoxItem Content="Coral Reef"/>
                        <ComboBoxItem Content="Aurora"/>
                        <!-- Blue bg -->
                        <ComboBoxItem Content="Deep Ocean"/>
                        <ComboBoxItem Content="Arctic Night"/>
                        <ComboBoxItem Content="Storm"/>
                        <ComboBoxItem Content="Winter"/>
                        <ComboBoxItem Content="Summer"/>
                        <ComboBoxItem Content="Sunset"/>
                        <ComboBoxItem Content="Midnight Gold"/>
                        <ComboBoxItem Content="Solarized"/>
                        <ComboBoxItem Content="Nord"/>
                        <!-- Blue-Purple bg -->
                        <ComboBoxItem Content="Tokyo Night"/>
                        <ComboBoxItem Content="Eclipse"/>
                        <ComboBoxItem Content="Dracula"/>
                        <ComboBoxItem Content="Twilight"/>
                        <ComboBoxItem Content="Synthwave"/>
                        <!-- Magenta / Dark Purple bg -->
                        <ComboBoxItem Content="Retrowave"/>
                        <ComboBoxItem Content="Galaxy"/>
                        <!-- Neutral / Black bg -->
                        <ComboBoxItem Content="Noir"/>
                        <ComboBoxItem Content="Cyberpunk"/>
                        <ComboBoxItem Content="Monokai"/>
                        <ComboBoxItem Content="High Contrast"/>

                        <!-- ── Three-colour  (sorted by background hue → accent hue) ── -->
                        <!-- Red bg -->
                        <ComboBoxItem Content="Bloodrite"/>
                        <ComboBoxItem Content="Inferno"/>
                        <!-- Vermilion bg -->
                        <ComboBoxItem Content="Magma"/>
                        <!-- Orange bg -->
                        <ComboBoxItem Content="Citrus Storm"/>
                        <!-- Amber bg -->
                        <ComboBoxItem Content="Desert Bloom"/>
                        <ComboBoxItem Content="Amber Waves"/>
                        <!-- Yellow bg -->
                        <ComboBoxItem Content="Bumblebee"/>
                        <!-- Olive bg -->
                        <ComboBoxItem Content="Venom"/>
                        <!-- Lime bg -->
                        <ComboBoxItem Content="Acid Wash"/>
                        <!-- Chartreuse bg -->
                        <ComboBoxItem Content="Toxic"/>
                        <!-- Green bg -->
                        <ComboBoxItem Content="Jungle Fire"/>
                        <ComboBoxItem Content="Emerald Crown"/>
                        <ComboBoxItem Content="Poison"/>
                        <!-- Teal bg -->
                        <ComboBoxItem Content="Dragon Jade"/>
                        <ComboBoxItem Content="Mermaid"/>
                        <ComboBoxItem Content="Carnival"/>
                        <!-- Cyan bg -->
                        <ComboBoxItem Content="Arctic Aurora"/>
                        <ComboBoxItem Content="Frozen Fire"/>
                        <!-- Blue bg -->
                        <ComboBoxItem Content="Monarch"/>
                        <ComboBoxItem Content="Circuit"/>
                        <ComboBoxItem Content="Blueprint"/>
                        <ComboBoxItem Content="Sapphire Flame"/>
                        <!-- Indigo bg -->
                        <ComboBoxItem Content="Starlight"/>
                        <ComboBoxItem Content="Nebula"/>
                        <!-- Purple bg -->
                        <ComboBoxItem Content="Twilight Fire"/>
                        <ComboBoxItem Content="Witchcraft"/>
                        <!-- Violet bg -->
                        <ComboBoxItem Content="Hex"/>
                        <!-- Magenta bg -->
                        <ComboBoxItem Content="Flamingo"/>
                        <ComboBoxItem Content="Cherry Bomb"/>
                        <!-- Dark bg -->
                        <ComboBoxItem Content="Neon Trinity"/>

                    </ComboBox>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="Light Mode" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                        <CheckBox x:Name="DarkModeToggle" Style="{StaticResource ToggleSwitch}"
                                  Checked="DarkMode_Changed" Unchecked="DarkMode_Changed"/>
                        <TextBlock Text="Dark Mode" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="UI Scale" Foreground="{DynamicResource TextPrimary}" FontWeight="Medium"/>
                            <TextBlock Text="Match to your monitor's vertical resolution so the app looks the same across screens."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ComboBox x:Name="UiScaleBox" Grid.Column="1" Width="110" VerticalAlignment="Center"
                                  SelectionChanged="UiScale_Changed">
                            <ComboBoxItem Content="1080p"/>
                            <ComboBoxItem Content="1440p"/>
                            <ComboBoxItem Content="2160p"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Game Scanning -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Game Scanning" Foreground="{DynamicResource TextPrimary}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <TextBlock Text="RAWG API Key:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RawgApiKeyBox" Height="36" IsReadOnly="True"
                                 Background="{DynamicResource AppBg}" Foreground="{DynamicResource TextSecondary}"
                                 BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="8,4"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                            <Button x:Name="RawgKeyEditButton" Content="Edit"
                                    Height="36" Width="60"
                                    Background="#89B4FA" Foreground="#1E1E2E" FontWeight="Bold"
                                    BorderThickness="0" Cursor="Hand" Click="RawgKeyEdit_Click"/>
                            <Button x:Name="RawgKeySaveButton" Content="Save"
                                    Height="36" Width="60" Visibility="Collapsed"
                                    Background="#A6E3A1" Foreground="#1E1E2E" FontWeight="Bold"
                                    BorderThickness="0" Cursor="Hand" Click="RawgKeySave_Click"/>
                            <Button x:Name="RawgKeyCancelButton" Content="Cancel"
                                    Height="36" Width="60" Visibility="Collapsed" Margin="4,0,0,0"
                                    Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextSecondary}"
                                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    Cursor="Hand" Click="RawgKeyCancel_Click"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="12"
                               Margin="0,6,0,0"
                               Text="Used to look up ESRB ratings during game scans. Mature and Adults Only games are automatically blocked when added. Click Edit to change the key."/>
                </StackPanel>
            </Border>

            <!-- Scan Rules (combined) -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Scan Rules" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="12"
                               Margin="0,0,0,16"
                               Text="Configure how games are automatically categorized when scanned. Expand a section to filter by genre or content tag."/>

                    <!-- ── Blocking ── -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Block at ESRB rating" Foreground="{DynamicResource TextPrimary}" FontWeight="Medium"/>
                            <TextBlock Text="Games rated at or above this level are automatically blocked on scan."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ComboBox x:Name="ScanBlockRatingBox" Grid.Column="1" Width="100" VerticalAlignment="Center"
                                  SelectionChanged="ScanBlockRating_Changed">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="E"/>
                            <ComboBoxItem Content="E10+"/>
                            <ComboBoxItem Content="T"/>
                            <ComboBoxItem Content="M"/>
                            <ComboBoxItem Content="AO"/>
                        </ComboBox>
                    </Grid>
                    <Expander Header="Block — Genres &amp; Tags" IsExpanded="False"
                              Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,0">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Block by genre" Foreground="{DynamicResource TextPrimary}"
                                       FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBlock Text="Games matching any selected genre are blocked on scan."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    CornerRadius="4" Padding="8" MaxHeight="110" Margin="0,0,0,12">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <WrapPanel x:Name="GenresPanel"/>
                                </ScrollViewer>
                            </Border>
                            <TextBlock Text="Block by content tag" Foreground="{DynamicResource TextPrimary}"
                                       FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBlock Text="Games with any selected tag are blocked on scan."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    CornerRadius="4" Padding="8" MaxHeight="110">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <WrapPanel x:Name="TagsPanel"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Expander>

                    <Separator Margin="0,16,0,16" Background="{DynamicResource BorderColor}"/>

                    <!-- ── App Time ── -->
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="12"
                               Margin="0,0,0,8"
                               Text="App Time and Focus Mode rules apply only when a game doesn't match a blocking rule."/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="App Time at ESRB rating" Foreground="{DynamicResource TextPrimary}" FontWeight="Medium"/>
                            <TextBlock Text="Games rated at or above this level are placed on app time."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ComboBox x:Name="ScanAppTimeRatingBox" Grid.Column="1" Width="100" VerticalAlignment="Center"
                                  SelectionChanged="ScanAppTimeRating_Changed">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="E"/>
                            <ComboBoxItem Content="E10+"/>
                            <ComboBoxItem Content="T"/>
                            <ComboBoxItem Content="M"/>
                            <ComboBoxItem Content="AO"/>
                        </ComboBox>
                    </Grid>
                    <Expander Header="App Time — Genres &amp; Tags" IsExpanded="False"
                              Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,0">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="By genre" Foreground="{DynamicResource TextPrimary}"
                                       FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBlock Text="Games matching any selected genre are placed on app time."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    CornerRadius="4" Padding="8" MaxHeight="110" Margin="0,0,0,12">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <WrapPanel x:Name="AppTimeGenresPanel"/>
                                </ScrollViewer>
                            </Border>
                            <TextBlock Text="By content tag" Foreground="{DynamicResource TextPrimary}"
                                       FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBlock Text="Games with any selected tag are placed on app time."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    CornerRadius="4" Padding="8" MaxHeight="110">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <WrapPanel x:Name="AppTimeTagsPanel"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Expander>

                    <Separator Margin="0,16,0,16" Background="{DynamicResource BorderColor}"/>

                    <!-- ── Focus Mode ── -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Focus Mode at ESRB rating" Foreground="{DynamicResource TextPrimary}" FontWeight="Medium"/>
                            <TextBlock Text="Games rated at or below this level are allowed during focus mode."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ComboBox x:Name="ScanFocusModeRatingBox" Grid.Column="1" Width="100" VerticalAlignment="Center"
                                  SelectionChanged="ScanFocusModeRating_Changed">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="E"/>
                            <ComboBoxItem Content="E10+"/>
                            <ComboBoxItem Content="T"/>
                            <ComboBoxItem Content="M"/>
                            <ComboBoxItem Content="AO"/>
                        </ComboBox>
                    </Grid>
                    <Expander Header="Focus Mode — Genres &amp; Tags" IsExpanded="False"
                              Foreground="{DynamicResource TextSecondary}">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="By genre" Foreground="{DynamicResource TextPrimary}"
                                       FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBlock Text="Games matching any selected genre are allowed during focus mode."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    CornerRadius="4" Padding="8" MaxHeight="110" Margin="0,0,0,12">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <WrapPanel x:Name="FocusModeGenresPanel"/>
                                </ScrollViewer>
                            </Border>
                            <TextBlock Text="By content tag" Foreground="{DynamicResource TextPrimary}"
                                       FontWeight="Medium" Margin="0,0,0,4"/>
                            <TextBlock Text="Games with any selected tag are allowed during focus mode."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,8"/>
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    CornerRadius="4" Padding="8" MaxHeight="110">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <WrapPanel x:Name="FocusModeTagsPanel"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Border>

            <!-- Reset options -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Reset" Foreground="{DynamicResource TextPrimary}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="12"
                               Margin="0,0,0,20"
                               Text="Use these options to restore parts of the app to their default state. Each action asks for confirmation before proceeding. Passwords are never reset to ensure access remains."/>

                    <!-- Reset Settings -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Reset Settings" Width="160" Height="36"
                                Background="#FAB387" Foreground="#1E1E2E" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand"
                                Click="ResetSettings_Click"/>
                        <TextBlock TextWrapping="Wrap" VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                   Text="Reset settings, keeps rules"/>
                    </StackPanel>

                    <!-- Reset Data -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Reset Data" Width="160" Height="36"
                                Background="#F38BA8" Foreground="#1E1E2E" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand"
                                Click="ResetData_Click"/>
                        <TextBlock TextWrapping="Wrap" VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                   Text="Reset application rules, keeps settings"/>
                    </StackPanel>

                    <!-- Full Reset -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Full Reset" Width="160" Height="36"
                                Background="#F38BA8" Foreground="#1E1E2E" FontWeight="Bold"
                                BorderThickness="0" Cursor="Hand"
                                Click="FullReset_Click"/>
                        <TextBlock TextWrapping="Wrap" VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                   Text="Resets everything back to default"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- DEBUG ONLY — hidden in Release builds via code-behind -->
            <Border x:Name="DebugSection" Visibility="Collapsed"
                    Background="#2A1500" BorderBrush="#FF8800" BorderThickness="2"
                    CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="⚠ DEBUG BUILD ONLY" FontWeight="Bold" FontSize="13"
                               Foreground="#FF8800" Margin="0,0,0,8"/>
                    <StackPanel Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock Text="Off" Foreground="#FFCC88" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                            <CheckBox x:Name="DebugStopServiceToggle" Style="{StaticResource ToggleSwitch}"
                                      Checked="DebugStopService_Changed"
                                      Unchecked="DebugStopService_Changed"/>
                            <TextBlock Text="On" Foreground="#FFCC88" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="#FFCC88" FontSize="12"
                                   Text="DEBUG TESTING ONLY: Turn off service after locking the computer to ensure testing mishaps don't lock developer out of machine"/>
                    </StackPanel>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock Text="Off" Foreground="#FFCC88" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                            <CheckBox x:Name="DebugAppTimeOverrideToggle" Style="{StaticResource ToggleSwitch}"
                                      Checked="DebugAppTimeOverride_Changed"
                                      Unchecked="DebugAppTimeOverride_Changed"/>
                            <TextBlock Text="On" Foreground="#FFCC88" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="#FFCC88" FontSize="12"
                                   Text="DEBUG TESTING ONLY: Override App Time limit to 6 minutes to test warning and enforcement quickly"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
