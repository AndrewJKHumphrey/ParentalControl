<Window x:Class="ParentalControl.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ParentGuard - Parental Control" Height="640" Width="960"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBg}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBg}" Padding="0,20,0,0">
            <StackPanel>
                <TextBlock Text="ParentGuard" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}" Margin="20,0,0,24"/>

                <Button Style="{StaticResource NavButton}" Content="  Dashboard"
                        Tag="Dashboard" Click="NavButton_Click"/>
                <Button Style="{StaticResource NavButton}" Content="  Screen Time"
                        Tag="ScreenTime" Click="NavButton_Click"/>
                <Button Style="{StaticResource NavButton}" Content="  App Control"
                        Tag="AppControl" Click="NavButton_Click"/>
                <Button Style="{StaticResource NavButton}" Content="  Web Filter"
                        Tag="WebFilter" Click="NavButton_Click"/>
                <Button Style="{StaticResource NavButton}" Content="  Activity Log"
                        Tag="ActivityLog" Click="NavButton_Click"/>
                <Button Style="{StaticResource NavButton}" Content="  Settings"
                        Tag="Settings" Click="NavButton_Click"/>
                
                <!-- Line Color needs to be in theme-->
                <Line X1="10" Y1="10" X2="175" Y2="10" Stroke="Gray" StrokeThickness="1" Margin="0,0,0,24"/>

                <TextBlock Text="Service Status: " FontSize="16" Foreground="{DynamicResource TextSecondary}" FontWeight="Bold" Margin="40,0,0,10"/>
                <TextBlock x:Name="ServiceStatusText" Text="Checking..." Foreground="#A6E3A1" FontSize="18" FontWeight="Bold" Margin="60,0,0,0"/>
                
                <Button x:Name="ServiceButton" Content="Shutdown Service" Margin="12,10,12,0"
                        Height="36" Background="#FAB387" Foreground="#1E1E2E"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                        Click="ServiceButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Frame x:Name="ContentFrame" Grid.Column="1" NavigationUIVisibility="Hidden"
               Background="{DynamicResource AppBg}"/>
    </Grid>
</Window>
